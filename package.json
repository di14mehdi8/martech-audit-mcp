{
  "name": "martech-audit-mcp",
  "version": "0.1.0",
  "description": "MCP server for automated martech stack auditing",
  "type": "module",
  "bin": {
    "martech-audit-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "dev:server": "tsx watch src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "start:web": "node build/server.js",
    "start": "node build/index.js",
    "audit": "tsx scripts/audit-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "playwright": "^1.51.1",
    "serve-static": "^2.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/serve-static": "^2.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
